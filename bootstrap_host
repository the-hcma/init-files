#!/usr/bin/env bash
# bootstrap_host — new-host path from house SSH key (or gh HTTPS) to working init-files.
#
# Preferred (public bootstrap — no prior clone required):
#
#   curl -fsSL https://raw.githubusercontent.com/the-hcma/init-files/main/bootstrap_host \
#     -o /tmp/bootstrap_host && chmod +x /tmp/bootstrap_host
#   /tmp/bootstrap_host --key-from HOST
#   # after "bootstrap_host verify" shows bashrc OK:
#   source ~/.bashrc
#
# --key-from HOST copies the house SSH key from HOST (one SSH login). Or set
# INIT_FILES_KEY_HOST. Do not source ~/.bashrc until verify succeeds.
#
# After clone exists, this script is idempotent. Keep the-hcma/init-files in sync
# when this file changes.
#
# See: https://github.com/thehcma/init-files/issues/12
set -euo pipefail
# bootstrap_host_rev=ed25519-only-ssh-2026-07-22b

clone_dir="${INIT_FILES_DIR:-$HOME/.local/share/init-files}"
repo_https="${INIT_FILES_REPO_HTTPS:-https://github.com/thehcma/init-files.git}"
house_key="${HOME}/.ssh/id_rsa-sha2-256-hcma-at-hcma-dot-info"
house_pub="${house_key}.pub"
github_ed25519_key="${HOME}/.ssh/id_ed25519_github"
# Selected GitHub identity after verify_github_ssh (absolute path).
github_key=""
ssh_dir="${HOME}/.ssh"
ssh_config_d="${ssh_dir}/config.d"
ssh_config_file="${ssh_dir}/config"
ssh_github_snippet="${ssh_config_d}/init-files-github.conf"
github_insteadof_from='https://github.com/'
github_insteadof_to='git@github.com:'
ssh_cache_timeout="${SSH_CACHE_TIMEOUT:-4h}"
# Optional: host (or user@host) to scp the house key from before SSH bootstrap.
key_from_host="${INIT_FILES_KEY_HOST:-}"

force=0
quiet=0
no_dev=0
dev_mode_explicit=0
github_https=0
github_transport_explicit=0
# Args forwarded to ./provision_init_files (built while parsing).
install_args=()

tools_dir="${XDG_CONFIG_HOME:-$HOME/.config}/init-files"

log()
{
    [[ $quiet -eq 1 ]] || printf '%s\n' "$*"
}

die()
{
    printf 'ERROR: %s\n' "$*" >&2
    exit 1
}

usage()
{
    cat <<'EOF'
Usage: bootstrap_host [-f|--force] [-q|--quiet] [--no-dev|--dev]
                      [--github-https|--github-ssh]
                      [--key-from HOST] [-h|--help]

  New-host bootstrap for init-files.

  SSH mode (default; or --github-ssh / remembered github-ssh.<host>):
    optional --key-from HOST → require house key → GitHub SSH snippet +
    insteadOf + known_hosts → cache key → ssh -T → clone (if needed) →
    ./provision_init_files → verify.

  --key-from HOST
                copy the house key (+ .pub if present) from HOST in one SSH
                login. HOST may be a hostname or user@host. Requires SSH
                access to HOST (password or existing key). Env alternative:
                INIT_FILES_KEY_HOST.

  HTTPS mode (--github-https / remembered github-https.<host> / gh auth):
    skip key/cache_ssh/ssh -T → clone via HTTPS → ./provision_init_files --github-https → verify.

  Preferred fetch:
    curl -fsSL https://raw.githubusercontent.com/the-hcma/init-files/main/bootstrap_host \
      | bash -s -- --key-from HOST

  Flags other than --key-from are forwarded to ./provision_init_files.
  Clone path: ~/.local/share/init-files (override with INIT_FILES_DIR).
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--force)
            force=1
            install_args+=("$1")
            shift
            ;;
        -q|--quiet)
            quiet=1
            install_args+=("$1")
            shift
            ;;
        --no-dev)
            no_dev=1
            dev_mode_explicit=1
            install_args+=("$1")
            shift
            ;;
        --dev)
            no_dev=0
            dev_mode_explicit=1
            install_args+=("$1")
            shift
            ;;
        --github-https)
            github_https=1
            github_transport_explicit=1
            install_args+=("$1")
            shift
            ;;
        --github-ssh)
            github_https=0
            github_transport_explicit=1
            install_args+=("$1")
            shift
            ;;
        --key-from)
            if [[ -z "${2:-}" || "$2" == -* ]]; then
                die "--key-from requires a host (e.g. meerkat or hcma@meerkat)"
            fi
            key_from_host="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "ERROR: unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

# force is only forwarded via install_args; keep the flag for future local use.
: "${force}"

# Same host key as install / PS1: macOS ComputerName, else short hostname.
_init_files_raw_host_label()
{
    local scutil_bin name
    if [[ "${OSTYPE:-}" == darwin* ]]; then
        scutil_bin="$(command -v scutil 2>/dev/null || true)"
        [[ -n "$scutil_bin" ]] || scutil_bin=/usr/sbin/scutil
        if [[ -x "$scutil_bin" ]]; then
            name="$("$scutil_bin" --get ComputerName 2>/dev/null || true)"
            if [[ -n "$name" ]]; then
                printf '%s\n' "$name"
                return 0
            fi
        fi
    fi
    hostname -s 2>/dev/null || hostname 2>/dev/null || echo host
}

_init_files_sanitize_host()
{
    local host="${1:-}"
    host="${host%%.*}"
    host="${host//[^A-Za-z0-9._-]/_}"
    [[ -n "$host" ]] || host="unknown-host"
    printf '%s\n' "$host"
}

init_files_host="$(_init_files_sanitize_host "$(_init_files_raw_host_label)")"
init_files_github_https_flag="${tools_dir}/github-https.${init_files_host}"
init_files_github_ssh_flag="${tools_dir}/github-ssh.${init_files_host}"
init_files_no_dev_flag="${tools_dir}/no-dev.${init_files_host}"

# Mirror install: remembered transport / gh auth when flag not explicit.
if [[ $github_transport_explicit -eq 0 ]]; then
    if [[ -f "$init_files_github_https_flag" ]]; then
        github_https=1
    elif [[ -f "$init_files_github_ssh_flag" ]]; then
        github_https=0
    else
        gh_bin="$(command -v gh 2>/dev/null || true)"
        if [[ -n "$gh_bin" && -x "$gh_bin" ]] && "$gh_bin" auth status >/dev/null 2>&1; then
            github_https=1
            log "GitHub: gh authenticated — preferring HTTPS on ${init_files_host}"
        fi
    fi
fi

# If --no-dev/--dev not passed, honor remembered no-dev (install will too).
if [[ $dev_mode_explicit -eq 0 && -f "$init_files_no_dev_flag" ]]; then
    no_dev=1
fi

require_cmd()
{
    local name="$1"
    command -v "$name" >/dev/null 2>&1 || die "$name is required but not on PATH"
}

# Hint when OpenSSH client tools are missing (ssh-agent / ssh-add / scp).
openssh_client_install_hint()
{
    if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        case "${ID:-}" in
            ubuntu|debian|linuxmint|pop)
                printf 'sudo apt update && sudo apt install -y openssh-client'
                return 0
                ;;
            rhel|centos|rocky|almalinux|fedora|amzn)
                if command -v dnf >/dev/null 2>&1; then
                    printf 'sudo dnf install -y openssh-clients'
                else
                    printf 'sudo yum install -y openssh-clients'
                fi
                return 0
                ;;
            arch|manjaro)
                printf 'sudo pacman -S openssh'
                return 0
                ;;
        esac
    fi
    if [[ "${OSTYPE:-}" == darwin* ]]; then
        printf 'xcode-select --install   # Xcode CLT provides ssh-agent/ssh-add'
        return 0
    fi
    printf 'install the OpenSSH client package (ssh, ssh-add, ssh-agent, scp)'
}

require_openssh_client()
{
    local missing=()
    local tool
    for tool in ssh ssh-add ssh-agent scp; do
        command -v "$tool" >/dev/null 2>&1 || missing+=("$tool")
    done
    if [[ ${#missing[@]} -eq 0 ]]; then
        return 0
    fi
    cat >&2 <<EOF
ERROR: missing OpenSSH client tool(s): ${missing[*]}

Install them, then re-run bootstrap_host:
  $(openssh_client_install_hint)
EOF
    exit 1
}

# Prefer a real terminal for passphrase prompts (curl|bash leaves stdin as a pipe).
bootstrap_tty()
{
    if [[ -r /dev/tty ]]; then
        printf '/dev/tty'
        return 0
    fi
    if [[ -t 0 ]]; then
        printf '/dev/stdin'
        return 0
    fi
    return 1
}

ensure_ssh_config_include()
{
    local include_line='Include config.d/*.conf'
    local tmp

    mkdir -p "$ssh_config_d" || die "cannot create $ssh_config_d"
    chmod 700 "$ssh_dir" || true

    if [[ ! -f "$ssh_config_file" ]]; then
        printf '%s\n' "$include_line" > "$ssh_config_file" || die "cannot write $ssh_config_file"
        chmod 600 "$ssh_config_file" || true
        log "Created  ~/.ssh/config with Include config.d/*.conf"
        return 0
    fi

    if grep -Eq '^[[:space:]]*Include[[:space:]]+config\.d/\*\.conf[[:space:]]*$' "$ssh_config_file"; then
        return 0
    fi

    tmp=$(mktemp) || die "mktemp failed"
    {
        printf '%s\n\n' "$include_line"
        cat "$ssh_config_file"
    } > "$tmp" || {
        rm -f "$tmp"
        die "cannot prepend Include to $ssh_config_file"
    }
    cp "$tmp" "$ssh_config_file" || {
        rm -f "$tmp"
        die "cannot update $ssh_config_file"
    }
    rm -f "$tmp"
    chmod 600 "$ssh_config_file" || true
    log "Prepended Include config.d/*.conf to ~/.ssh/config"
}

# OpenSSH < 8.5: PubkeyAcceptedKeyTypes; >= 8.5: PubkeyAcceptedAlgorithms.
# Forcing rsa-sha2-* avoids RHEL crypto-policies offering only legacy ssh-rsa (SHA-1),
# which GitHub rejects.
github_ssh_rsa_sha2_opt()
{
    local major=0 minor=0
    # ssh -V → OpenSSH_8.0p1, ...
    if [[ "$(ssh -V 2>&1)" =~ OpenSSH_([0-9]+)\.([0-9]+) ]]; then
        major="${BASH_REMATCH[1]}"
        minor="${BASH_REMATCH[2]}"
    fi
    if (( major > 8 || (major == 8 && minor >= 5) )); then
        printf '%s\n' "PubkeyAcceptedAlgorithms=rsa-sha2-512,rsa-sha2-256"
    else
        printf '%s\n' "PubkeyAcceptedKeyTypes=rsa-sha2-512,rsa-sha2-256"
    fi
}

# Embedded GitHub Host block. Only lists IdentityFiles that exist on this host
# (a missing IdentityFile + IdentitiesOnly can abort auth before later keys).
# Order: prefer github_key from verify when set; else house RSA then ed25519.
write_github_ssh_snippet()
{
    local alg_line="" id
    local -a ids=()

    mkdir -p "$ssh_config_d" || die "cannot create $ssh_config_d"

    if [[ "${github_key:-}" == "$github_ed25519_key" ]]; then
        [[ -f "$github_ed25519_key" ]] && ids+=("$github_ed25519_key")
        [[ -f "$house_key" ]] && ids+=("$house_key")
    else
        # house RSA preferred (policy / pre-verify default), then ed25519 if present
        [[ -f "$house_key" ]] && ids+=("$house_key")
        [[ -f "$github_ed25519_key" ]] && ids+=("$github_ed25519_key")
    fi

    if ((${#ids[@]} == 0)); then
        die "no GitHub SSH keys on disk ($house_key or $github_ed25519_key)"
    fi

    if [[ " ${ids[*]} " == *" $house_key "* ]]; then
        alg_line="    $(github_ssh_rsa_sha2_opt | sed 's/=/ /')"$'\n'
    fi

    {
        printf '%s\n' \
            '# Managed by init-files bootstrap_host (mirrors ssh/config.github).' \
            '# provision_init_files may refresh this file from the clone.' \
            '' \
            'Host github.com' \
            '    HostName github.com' \
            '    User git'
        for id in "${ids[@]}"; do
            printf '    IdentityFile %s\n' "$id"
        done
        printf '%s' "$alg_line"
        printf '%s\n' '    IdentitiesOnly yes' '    VisualHostKey no'
    } > "$ssh_github_snippet" || die "cannot write $ssh_github_snippet"
    chmod 600 "$ssh_github_snippet" || true
    log "Installed ${ssh_github_snippet/#$HOME/~} (keys: ${ids[*]})"
}

ensure_github_known_hosts()
{
    local known="${ssh_dir}/known_hosts"

    mkdir -p "$ssh_dir" || return 1
    touch "$known" || return 1
    chmod 600 "$known" || true

    if grep -qE '^(github\.com|[0-9.]+\s+.*github)' "$known" 2>/dev/null \
        || grep -q ' github.com ' "$known" 2>/dev/null
    then
        return 0
    fi

    if command -v ssh-keyscan >/dev/null 2>&1; then
        ssh-keyscan -t ed25519,rsa github.com >> "$known" 2>/dev/null || true
        if grep -q 'github.com' "$known" 2>/dev/null; then
            log "Added    github.com to ~/.ssh/known_hosts"
        else
            log "WARN     could not ssh-keyscan github.com"
        fi
    fi
}

set_github_ssh_insteadof()
{
    local git_bin
    git_bin="$(command -v git 2>/dev/null || true)"
    [[ -n "$git_bin" && -x "$git_bin" ]] || die "git is required to clone init-files"

    if [[ "$("$git_bin" config --global --get "url.${github_insteadof_to}.insteadof" 2>/dev/null || true)" == "$github_insteadof_from" ]]; then
        log "OK       git url.${github_insteadof_to}.insteadOf -> ${github_insteadof_from}"
    else
        "$git_bin" config --global "url.${github_insteadof_to}.insteadOf" "$github_insteadof_from" \
            || die "failed to set git insteadOf for GitHub SSH"
        log "Set      git url.${github_insteadof_to}.insteadOf ${github_insteadof_from}"
    fi
}

clear_github_ssh_insteadof()
{
    local git_bin existing
    git_bin="$(command -v git 2>/dev/null || true)"
    [[ -n "$git_bin" && -x "$git_bin" ]] || die "git is required to clone init-files"
    existing=$("$git_bin" config --global --get "url.${github_insteadof_to}.insteadof" 2>/dev/null || true)
    if [[ -n "$existing" ]]; then
        "$git_bin" config --global --unset-all "url.${github_insteadof_to}.insteadOf" 2>/dev/null || true
        log "Cleared  git https→ssh insteadOf (HTTPS mode)"
    else
        log "OK       no https→ssh insteadOf (HTTPS mode)"
    fi
}

# Minimal cache_ssh: agent + ssh-add -t for one key (passphrase via /dev/tty when possible).
cache_ssh_key()
{
    local key_path="$1"
    local label="${2:-$key_path}"
    local ssh_add_cmd ssh_agent_cmd ssh_keygen_cmd env_file agent_rc fingerprint key_loaded tty_dev agent_out

    [[ -f "$key_path" ]] || return 1
    require_openssh_client

    ssh_add_cmd="$(command -v ssh-add)"
    ssh_agent_cmd="$(command -v ssh-agent)"
    ssh_keygen_cmd="$(command -v ssh-keygen 2>/dev/null || true)"
    env_file="${HOME}/.ssh/environment"

    agent_rc=0
    if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
        agent_rc=2
    else
        "$ssh_add_cmd" -l &>/dev/null || agent_rc=$?
    fi

    if [[ $agent_rc -eq 2 ]]; then
        if [[ -f "$env_file" ]]; then
            # shellcheck disable=SC1090
            . "$env_file" >/dev/null || true
            agent_rc=0
            "$ssh_add_cmd" -l &>/dev/null || agent_rc=$?
        fi
    fi

    if [[ $agent_rc -eq 2 ]]; then
        log "Starting ssh-agent …"
        agent_out="$("$ssh_agent_cmd" -s)" || die "failed to start ssh-agent"
        # shellcheck disable=SC2086
        eval "$agent_out" >/dev/null
        {
            printf 'SSH_AUTH_SOCK=%q; export SSH_AUTH_SOCK;\n' "${SSH_AUTH_SOCK:-}"
            printf 'SSH_AGENT_PID=%q; export SSH_AGENT_PID;\n' "${SSH_AGENT_PID:-}"
        } > "$env_file" 2>/dev/null || true
        chmod 600 "$env_file" 2>/dev/null || true
        agent_rc=0
        "$ssh_add_cmd" -l &>/dev/null || agent_rc=$?
    fi

    # ssh-add -l: 0 = has keys, 1 = agent up but empty, 2 = no agent.
    if [[ $agent_rc -eq 2 ]]; then
        cat >&2 <<EOF
ERROR: ssh-agent is not available (cannot connect via SSH_AUTH_SOCK=${SSH_AUTH_SOCK:-unset}).

Install/fix OpenSSH client, then re-run:
  $(openssh_client_install_hint)
EOF
        exit 1
    fi

    key_loaded=0
    if [[ -n "$ssh_keygen_cmd" ]]; then
        fingerprint=$("$ssh_keygen_cmd" -lf "$key_path" 2>/dev/null | awk '{print $2}')
        if [[ -n "$fingerprint" ]] && "$ssh_add_cmd" -l 2>/dev/null | grep -qF "$fingerprint"; then
            key_loaded=1
        fi
    fi

    if [[ $key_loaded -eq 1 ]]; then
        log "OK       SSH key already cached: $label"
        return 0
    fi

    if ! tty_dev="$(bootstrap_tty)"; then
        die "passphrase required but no TTY; run from a real terminal (not a non-interactive pipe without /dev/tty)"
    fi

    log "Caching SSH key: $label (timeout: $ssh_cache_timeout)"
    log "         Enter the key passphrase when prompted."
    if ! env -u DISPLAY -u SSH_ASKPASS SSH_ASKPASS_REQUIRE=never \
        "$ssh_add_cmd" -t "$ssh_cache_timeout" "$key_path" <"$tty_dev"
    then
        die "ssh-add failed for $label (wrong passphrase, or agent issue)"
    fi
    log "OK       cached in ssh-agent: $label"
}

cache_house_key()
{
    cache_ssh_key "$house_key" "$house_key"
}

# Try ssh -T with one IdentityFile. Prints Hi-line on success. Sets github_key.
try_github_ssh_identity()
{
    local key_path="$1"
    local out
    local -a ssh_opts

    [[ -f "$key_path" ]] || return 1

    ssh_opts=(
        -o "User=git"
        -o "IdentitiesOnly=yes"
        -o "IdentityFile=${key_path}"
        -o "PreferredAuthentications=publickey"
        -o "PubkeyAuthentication=yes"
        -o "BatchMode=yes"
        -o "ConnectTimeout=15"
    )
    if [[ "$key_path" == "$house_key" ]]; then
        ssh_opts+=(-o "$(github_ssh_rsa_sha2_opt)")
    fi

    out=$(ssh "${ssh_opts[@]}" -T git@github.com 2>&1) || true
    if printf '%s\n' "$out" | grep -qiE 'successfully authenticated|Hi .+!'; then
        github_key="$key_path"
        log "OK       $out"
        log "OK       GitHub SSH via ${key_path/#$HOME/~}"
        return 0
    fi
    return 1
}

verify_github_ssh()
{
    local verbose_tail fp ssh_ver try_key
    local -a verbose_opts

    log "Checking  ssh -T git@github.com …"

    # Prefer house RSA when present; else / fallback id_ed25519_github (FIPS / GitHub-only hosts).
    if [[ -f "$house_key" ]] && try_github_ssh_identity "$house_key"; then
        write_github_ssh_snippet
        return 0
    fi
    if [[ -f "$house_key" ]]; then
        log "WARN     house RSA declined by GitHub; trying ${github_ed25519_key/#$HOME/~} …"
    fi

    if [[ -f "$github_ed25519_key" ]]; then
        cache_ssh_key "$github_ed25519_key" "$github_ed25519_key" || true
        if try_github_ssh_identity "$github_ed25519_key"; then
            write_github_ssh_snippet
            return 0
        fi
    fi

    fp=
    [[ -f "$house_key" ]] && fp=$(ssh-keygen -lf "$house_key" 2>/dev/null | awk '{print $1" "$2}' || true)
    [[ -z "$fp" && -f "$github_ed25519_key" ]] \
        && fp=$(ssh-keygen -lf "$github_ed25519_key" 2>/dev/null | awk '{print $1" "$2}' || true)
    ssh_ver=$(ssh -V 2>&1 || true)
    try_key="$house_key"
    [[ -f "$try_key" ]] || try_key="$github_ed25519_key"
    verbose_opts=(
        -v -o BatchMode=yes -o User=git -o IdentitiesOnly=yes
        -o "IdentityFile=${try_key}"
    )
    if [[ -f "$house_key" && "$try_key" == "$house_key" ]]; then
        verbose_opts+=(-o "$(github_ssh_rsa_sha2_opt)")
    fi
    verbose_tail=$(ssh "${verbose_opts[@]}" -T git@github.com 2>&1 | tail -n 25 || true)

    cat >&2 <<EOF

ERROR: GitHub SSH auth failed (house RSA and ed25519).

  house RSA: $house_key $([[ -f "$house_key" ]] && echo present || echo MISSING)
  key fp:    ${fp:-unknown}
  ssh:       ${ssh_ver:-unknown}
  ed25519:   ${github_ed25519_key} $([[ -f "$github_ed25519_key" ]] && echo present || echo MISSING)

GitHub-only hosts (no house RSA): copy id_ed25519_github from saratoga, then re-run:

  scp hcma@saratoga:.ssh/id_ed25519_github{,.pub} ~/.ssh/
  chmod 600 ~/.ssh/id_ed25519_github
  ssh-add -t 4h ~/.ssh/id_ed25519_github
  /tmp/bootstrap_host --github-ssh

Or use HTTPS:  bootstrap_host --github-https

ssh -v (tail):
$verbose_tail
EOF
    exit 1
}

# Copy house key (+ optional .pub) from a donor host in one SSH auth (one password).
fetch_house_key_from_host()
{
    local src_host="$1"
    local key_basename="id_rsa-sha2-256-hcma-at-hcma-dot-info"
    local remote_script

    [[ -n "$src_host" ]] || die "fetch_house_key_from_host: empty host"
    require_openssh_client

    mkdir -p "$ssh_dir" || die "cannot create $ssh_dir"
    chmod 700 "$ssh_dir" || true

    if [[ -f "$house_key" && $force -eq 0 ]]; then
        log "OK       house key already present; skip fetch from ${src_host} (use -f to overwrite)"
        return 0
    fi

    log "Fetching house key from ${src_host} (single SSH login) …"
    log "         (needs SSH access to ${src_host} — password or an existing key)"

    # One ssh connection: stream key (+ pub if present) as a tar to avoid two scp passwords.
    remote_script=$(cat <<EOF
set -e
cd "\${HOME}/.ssh" || exit 1
test -f ${key_basename} || { echo "missing ~/.ssh/${key_basename} on remote" >&2; exit 1; }
if test -f ${key_basename}.pub; then
  tar cf - ${key_basename} ${key_basename}.pub
else
  tar cf - ${key_basename}
fi
EOF
)
    # shellcheck disable=SC2029
    if ! ssh -o ControlMaster=no "$src_host" "$remote_script" | tar -C "$ssh_dir" -xf -; then
        die "failed to fetch house key from ${src_host}. Check SSH access, then retry."
    fi
    [[ -f "$house_key" ]] || die "fetch produced no $house_key"
    chmod 600 "$house_key" || true
    if [[ -f "$house_pub" ]]; then
        chmod 644 "$house_pub" || true
        log "OK       fetched key + pubkey from ${src_host}"
    else
        log "OK       fetched private key from ${src_host} (no pubkey on remote)"
    fi
}

setup_ssh_mode()
{
    if [[ -n "$key_from_host" ]]; then
        fetch_house_key_from_host "$key_from_host"
    fi

    mkdir -p "$ssh_dir"
    chmod 700 "$ssh_dir" || true

    if [[ -f "$house_key" ]]; then
        chmod 600 "$house_key" || true
        if [[ -f "$house_pub" ]]; then
            chmod 644 "$house_pub" || true
        fi
        log "OK       house key present (${house_key/#$HOME/~})"
    elif [[ -f "$github_ed25519_key" ]]; then
        chmod 600 "$github_ed25519_key" || true
        log "OK       GitHub ed25519 present (${github_ed25519_key/#$HOME/~}); no house RSA on this host"
    else
        cat >&2 <<EOF
ERROR: no GitHub SSH key on this host.

Need one of:
  $house_key
  $github_ed25519_key

House key (also used for house hops):
  bootstrap_host --key-from HOST    # e.g. meerkat / hcma@meerkat

GitHub-only ed25519 (no house RSA on this host):
  scp hcma@saratoga:.ssh/id_ed25519_github{,.pub} ~/.ssh/
  chmod 600 ~/.ssh/id_ed25519_github
  bootstrap_host --github-ssh

Or use HTTPS:  bootstrap_host --github-https
EOF
        exit 1
    fi

    require_cmd git
    require_cmd ssh
    ensure_ssh_config_include
    write_github_ssh_snippet
    set_github_ssh_insteadof
    ensure_github_known_hosts
    if [[ -f "$house_key" ]]; then
        cache_house_key
    elif [[ -f "$github_ed25519_key" ]]; then
        cache_ssh_key "$github_ed25519_key" "$github_ed25519_key"
    fi
    verify_github_ssh
}

setup_https_mode()
{
    require_cmd git
    clear_github_ssh_insteadof

    local gh_bin
    gh_bin="$(command -v gh 2>/dev/null || true)"
    if [[ -n "$gh_bin" && -x "$gh_bin" ]] && "$gh_bin" auth status >/dev/null 2>&1; then
        log "OK       gh authenticated (HTTPS git)"
    else
        log "WARN     gh not logged in; HTTPS clone may prompt for credentials"
        log "         Prefer: gh auth login   then re-run with --github-https"
    fi

    # Ensure install receives --github-https even when preference was remembered.
    if [[ $github_transport_explicit -eq 0 ]]; then
        install_args+=(--github-https)
    fi
}

clone_repo_if_needed()
{
    require_cmd git
    if [[ -d "$clone_dir/.git" ]]; then
        log "OK       clone already present: $clone_dir"
        return 0
    fi

    if [[ -e "$clone_dir" ]] && [[ ! -d "$clone_dir/.git" ]]; then
        die "$clone_dir exists but is not a git clone; move it aside and re-run"
    fi

    mkdir -p "$(dirname "$clone_dir")" || die "cannot create $(dirname "$clone_dir")"
    log "Cloning  $repo_https -> $clone_dir"
    # Force the same GitHub SSH identity as verify (do not rely on Include alone).
    if [[ $github_https -eq 0 ]]; then
        local id="${github_key:-$github_ed25519_key}"
        [[ -f "$id" ]] || id="$house_key"
        if [[ "$id" == "$house_key" ]]; then
            GIT_SSH_COMMAND="ssh -o User=git -o IdentitiesOnly=yes -o IdentityFile=${id} -o $(github_ssh_rsa_sha2_opt)" \
                git clone "$repo_https" "$clone_dir" || die "git clone failed"
        else
            GIT_SSH_COMMAND="ssh -o User=git -o IdentitiesOnly=yes -o IdentityFile=${id}" \
                git clone "$repo_https" "$clone_dir" || die "git clone failed"
        fi
    else
        git clone "$repo_https" "$clone_dir" || die "git clone failed"
    fi
}

run_install()
{
    local install_bin="${clone_dir}/provision_init_files"
    [[ -x "$install_bin" ]] || die "missing executable $install_bin"

    log "Running  $install_bin ${install_args[*]:-}"
    # shellcheck disable=SC2086
    "$install_bin" ${install_args[@]+"${install_args[@]}"}
}

print_verify_summary()
{
    local head_sha tools_file link_target instead

    printf '\n=== bootstrap_host verify (%s) ===\n' "$init_files_host"

    if [[ -L "${HOME}/.bashrc" ]]; then
        link_target=$(readlink "${HOME}/.bashrc" 2>/dev/null || true)
        printf 'bashrc:   %s -> %s\n' "${HOME}/.bashrc" "$link_target"
        if [[ "$link_target" == "${clone_dir}/bashrc" ]]; then
            printf '          OK (symlink into clone)\n'
        else
            printf '          WARN (expected %s/bashrc)\n' "$clone_dir"
        fi
    else
        printf 'bashrc:   WARN ~/.bashrc is not a symlink\n'
    fi

    if [[ -d "$clone_dir/.git" ]]; then
        head_sha=$(git -C "$clone_dir" rev-parse --short HEAD 2>/dev/null || echo '?')
        printf 'HEAD:     %s\n' "$head_sha"
    else
        printf 'HEAD:     missing clone\n'
    fi

    if [[ -f "${tools_dir}/tools.${init_files_host}" ]]; then
        tools_file="${tools_dir}/tools.${init_files_host}"
    elif [[ -f "${tools_dir}/tools" ]]; then
        tools_file="${tools_dir}/tools"
    else
        tools_file=
    fi
    if [[ -n "$tools_file" ]]; then
        printf 'tools:    %s\n' "$tools_file"
    else
        printf 'tools:    WARN missing tools file under %s\n' "$tools_dir"
    fi

    if [[ $github_https -eq 1 ]]; then
        printf 'GitHub:   HTTPS mode\n'
        if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
            printf '          gh auth: OK\n'
        else
            printf '          gh auth: not logged in (may need credentials)\n'
        fi
    else
        instead=$(git config --global --get "url.${github_insteadof_to}.insteadof" 2>/dev/null || true)
        printf 'GitHub:   SSH mode (insteadOf=%s)\n' "${instead:-unset}"
        if ssh -o BatchMode=yes -o ConnectTimeout=10 -T git@github.com 2>&1 | grep -qiE 'successfully authenticated|Hi .+!'; then
            printf '          ssh -T: OK\n'
        else
            printf '          ssh -T: FAIL (run: cache_ssh && ssh -T git@github.com)\n'
        fi
    fi

    printf '\nNext: source ~/.bashrc   (or open a new shell)\n'
    if [[ $no_dev -eq 0 ]]; then
        printf 'Optional: check_tool_versions\n'
    fi
}

# --- main --------------------------------------------------------------------

printf 'bootstrap_host (%s) starting on %s…\n' \
    "ed25519-only-ssh-2026-07-22b" "${init_files_host}"

if [[ $github_https -eq 1 ]]; then
    log "Mode:    HTTPS GitHub on ${init_files_host}"
    setup_https_mode
else
    log "Mode:    SSH GitHub on ${init_files_host}"
    setup_ssh_mode
fi

clone_repo_if_needed
run_install
print_verify_summary
